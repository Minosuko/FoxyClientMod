{
    "schemaVersion": 1,
    "id": "foxyclient",
    "version": "${version}",
    "accessWidener": "foxyclient.accesswidener",
    "name": "FoxyClient",
    "description": "A unified Minecraft client mod combining Meteor, SeedCracker, and Baritone features.",
    "authors": [
        "Minosuko"
    ],
    "contact": {
        "email": "quynhmino206@gmail.com",
        "website": "https://foxyclient.qzz.io",
        "issues": "https://github.com/Minosuko/FoxyClientMods/issues",
        "homepage": "https://foxyclient.qzz.io"
    },
    "license": "MIT",
    "icon": "assets/foxyclient/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "com.foxyclient.seedcracker.FoxySeedCracker",
            "com.foxyclient.FoxyClient"
        ]
    },
    "mixins": [
        "foxyclient.mixins.json"
    ],
    "custom": {
        "fabric-api:mod": {
            "client-only": true
        },
        "fabric-networking-api-v1:requires": {
            "foxyclient": []
        }
    },
    "depends": {
        "fabricloader": ">=0.18.0",
        "minecraft": "~1.21.11",
        "java": ">=21",
        "fabric-api": "*"
    }
}